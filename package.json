{
  "name": "github-readme-card",
  "private": true,
  "version": "0.1.0",
  "description": "Personal GitHub stats SVG card for README profile.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch scripts/dev.ts",
    "start": "tsx scripts/dev.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "hono": "4.12.18",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@hono/node-server": "2.0.2",
    "@types/node": "22.10.0",
    "@vitest/coverage-v8": "4.1.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
